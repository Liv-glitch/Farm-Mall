# FarmMall backend environment — copy to .env (or set these in the cPanel Node App UI)
# Safe placeholder values only. Do NOT commit a real .env.

# --- Application ---
NODE_ENV=production
PORT=3000
API_VERSION=v1
# Public URL of THIS backend (used in Swagger + startup logs)
API_PUBLIC_URL=https://api.yourdomain.com

# --- Database (Namecheap cPanel MySQL / MariaDB) ---
# cPanel provides discrete credentials; the DB usually runs on localhost.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpaneluser_farmmall
DB_USER=cpaneluser_farmmall
DB_PASSWORD=change_me
# Set DB_SSL=true ONLY if connecting to a remote DB that requires TLS.
DB_SSL=false
# Optional: full connection string override. Leave blank to use the discrete DB_* vars above.
DATABASE_URL=

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
BCRYPT_SALT_ROUNDS=12

# --- CORS ---
# Comma-separated list of allowed browser origins (no trailing slash).
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Redis (OPTIONAL — disabled by default on shared hosting) ---
# Leave ENABLE_REDIS=false on Namecheap shared hosting; queue work runs synchronously.
ENABLE_REDIS=false
# Only used when ENABLE_REDIS=true:
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- File storage (Supabase) ---
# Required only when uploads are enabled.
ENABLE_UPLOADS=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change_me
SUPABASE_STORAGE_BUCKET=farm-documents

# --- AI services (OPTIONAL — features degrade gracefully if unset) ---
GEMINI_API_KEY=
# Gemini is enabled when GEMINI_API_KEY is set. Set USE_GEMINI=false to disable it explicitly.
USE_GEMINI=
OPENAI_API_KEY=
PLANTID_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=
HF_API_TOKEN=
HF_POTATO_MODEL_ID=24f2004275/potato-disease-classifier
HF_POTATO_MIN_CONFIDENCE=0.70
HF_POTATO_HIGH_CONFIDENCE=0.80

# --- Weather (OPTIONAL) ---
OPENWEATHER_API_KEY=
WEATHER_API_KEY=

# --- Email / SMTP (OPTIONAL) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- WhatsApp (OPTIONAL) ---
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Admin bootstrap (OPTIONAL — used by `npm run admin:bootstrap`) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
ADMIN_COUNTY=
ADMIN_SUB_COUNTY=

# --- Rate limiting / logging ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
LOG_FILE=logs/app.log
